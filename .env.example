# Server-side only. Never expose this value through NEXT_PUBLIC_* variables.
OPENAI_API_KEY=your_openai_api_key_here

# Live-mode budget controls. The code never allows more than 3 live runs per browser session.
MAX_LIVE_RUNS_PER_SESSION=3
# Set to 1 to disable all live model calls immediately; fixture mode remains available.
DAILY_SPEND_KILL=0
